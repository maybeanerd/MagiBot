{
  "name": "magibot",
  "version": "3.2.71",
  "description": "MagiBot - a Discord bot to build communities",
  "main": "dist/index.js",
  "engines": {
    "node": "22.22.2"
  },
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "dependencies": {
    "@discordjs/builders": "1.14.0",
    "@discordjs/rest": "2.6.1",
    "@discordjs/voice": "0.19.2",
    "@snazzah/davey": "0.1.11",
    "axios": "1.14.0",
    "blapi": "3.1.2",
    "bufferutil": "4.1.0",
    "discord-api-types": "0.38.43",
    "discord.js": "14.26.0",
    "dotenv": "17.3.1",
    "fast-folder-size": "2.4.0",
    "ffmpeg-static": "5.3.0",
    "ffprobe": "1.1.2",
    "forever": "4.0.3",
    "libsodium-wrappers": "0.8.2",
    "mongoose": "9.3.3",
    "opusscript": "0.1.1",
    "posthog-node": "5.28.9",
    "tweetnacl": "1.0.3",
    "utf-8-validate": "6.0.6"
  },
  "optionalDependencies": {
    "@discordjs/opus": "0.10.0",
    "sodium": "3.0.2",
    "zlib-sync": "0.1.10"
  },
  "devDependencies": {
    "@types/centra": "2.2.3",
    "@types/ffprobe": "1.1.8",
    "@types/node": "22.19.15",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "eslint": "10.1.0",
    "eslint-config-airbnb-base": "15.0.0",
    "rimraf": "6.1.3",
    "typescript": "5.9.3"
  },
  "scripts": {
    "install-dev": "npm i --no-optional",
    "dev": "npm run build && node dist/index.js",
    "lint": "eslint \"src/**/*\"",
    "lint:fix": "eslint \"src/**/*\" --fix",
    "build": "rimraf ./dist && tsc",
    "start": "node dist/index.js",
    "start:forever": "forever start dist/index.js",
    "stop": "forever stop dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maybeanerd/MagiBot.git"
  },
  "author": "Sebastian Di Luzio",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/maybeanerd/MagiBot/issues"
  },
  "homepage": "https://github.com/maybeanerd/MagiBot#readme"
}
